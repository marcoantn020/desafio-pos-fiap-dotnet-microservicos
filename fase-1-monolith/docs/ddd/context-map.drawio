          <mxGeometry x="240" y="60" width="120" height="140" as="geometry" />
        </mxCell>

        <!-- Password Value Object -->
        <mxCell id="vo_password" value="&lt;b&gt;Password&lt;/b&gt;&#xa;(Value Object)&#xa;─────────────────&#xa;+ Hash: string&#xa;─────────────────&#xa;Regra: min 8 chars&#xa;upper+lower&#xa;+digit+special" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6D0FF;strokeColor=#9673A6;fontColor=#1a1a1a;fontSize=11;align=left;" vertex="1" parent="bc_user_container">
          <mxGeometry x="240" y="220" width="120" height="140" as="geometry" />
        </mxCell>

        <!-- Endpoints in User Management -->
