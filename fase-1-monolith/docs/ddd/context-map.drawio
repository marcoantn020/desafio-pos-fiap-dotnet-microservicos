        <!-- ============================================================ -->
        <mxCell id="bc_promo_container" value="&lt;b&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Promotions&lt;/font&gt;&lt;/b&gt;" style="swimlane;startSize=40;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#7d4e00;rounded=1;arcSize=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1000" y="100" width="420" height="380" as="geometry" />
        </mxCell>

        <!-- Promotion Aggregate -->
        <mxCell id="agg_promo" value="&lt;b&gt;Promotion&lt;/b&gt;&#xa;(Aggregate Root)&#xa;─────────────────&#xa;+ Id: Guid&#xa;+ Title: string&#xa;+ Description: string&#xa;+ DiscountPercent: int (1-100)&#xa;+ StartsAt: DateTime&#xa;+ EndsAt: DateTime&#xa;+ CreatedAt: DateTime" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFD700;strokeColor=#CC9900;fontColor=#1a1a1a;fontSize=11;align=left;" vertex="1" parent="bc_promo_container">
