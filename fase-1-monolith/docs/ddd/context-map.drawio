        </mxCell>

        <!-- User Aggregate -->
        <mxCell id="agg_user" value="&lt;b&gt;User&lt;/b&gt;&#xa;(Aggregate Root)&#xa;─────────────────&#xa;+ Id: Guid&#xa;+ Name: string&#xa;+ Email: Email (VO)&#xa;+ PasswordHash: string&#xa;+ Role: enum (User/Admin)&#xa;+ CreatedAt: DateTime" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFD700;strokeColor=#CC9900;fontColor=#1a1a1a;fontSize=11;align=left;" vertex="1" parent="bc_user_container">
