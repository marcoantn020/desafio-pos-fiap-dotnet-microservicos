        <mxCell id="bc_catalog_container" value="&lt;b&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Game Catalog&lt;/font&gt;&lt;/b&gt;" style="swimlane;startSize=40;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#1a5e1a;rounded=1;arcSize=5;strokeWidth=2;" vertex="1" parent="1">
