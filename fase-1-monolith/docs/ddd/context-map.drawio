          <mxGeometry x="20" y="290" width="200" height="70" as="geometry" />
        </mxCell>

        <!-- VO ownership edges (inside container) -->
        <mxCell id="e_user_email" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#9673A6;dashed=1;endArrow=open;" edge="1" source="agg_user" target="vo_email" parent="bc_user_container">
