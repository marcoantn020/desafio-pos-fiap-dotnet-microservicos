          <mxGeometry x="20" y="280" width="380" height="80" as="geometry" />
        </mxCell>

        <!-- PromotionGame → Promotion edge -->
        <mxCell id="e_pg_p" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#b85450;endArrow=ERmany;startArrow=ERone;exitX=0;exitY=0.5;" edge="1" source="ent_promo_game" target="agg_promo" parent="bc_promo_container">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

