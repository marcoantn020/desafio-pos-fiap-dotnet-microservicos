        <!-- PromotionGame Entity -->
        <mxCell id="ent_promo_game" value="&lt;b&gt;PromotionGame&lt;/b&gt;&#xa;(Entity)&#xa;─────────────────&#xa;+ PromotionId: Guid (FK)&#xa;+ GameId: Guid (FK)&#xa;+ AddedAt: DateTime" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#1a1a1a;fontSize=11;align=left;" vertex="1" parent="bc_promo_container">
