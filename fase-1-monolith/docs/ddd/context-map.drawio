        <!-- ============================================================ -->
        <mxCell id="bc_library_container" value="&lt;b&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Library&lt;/font&gt;&lt;/b&gt;" style="swimlane;startSize=40;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#6d1313;rounded=1;arcSize=5;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="540" y="580" width="420" height="320" as="geometry" />
        </mxCell>

        <!-- LibraryItem Entity -->
        <mxCell id="ent_library" value="&lt;b&gt;LibraryItem&lt;/b&gt;&#xa;(Entity)&#xa;─────────────────&#xa;+ UserId: Guid (FK → User)&#xa;+ GameId: Guid (FK → Game)&#xa;+ AcquiredAt: DateTime&#xa;─────────────────&#xa;UK: (UserId, GameId)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFD700;strokeColor=#CC9900;fontColor=#1a1a1a;fontSize=11;align=left;" vertex="1" parent="bc_library_container">
