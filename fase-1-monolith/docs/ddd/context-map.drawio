        <!-- Game Catalog → Library (Game provides identity to Library) -->
        <mxCell id="rel_catalog_library" value="&lt;b&gt;GameId reference&lt;/b&gt;&#xa;(Customer/Supplier)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#1a5e1a;strokeWidth=2;fontColor=#1a5e1a;fontSize=11;endArrow=open;startArrow=none;" edge="1" source="bc_catalog_container" target="bc_library_container" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Game Catalog → Promotions (Game referenced in PromotionGame) -->
        <mxCell id="rel_catalog_promo" value="&lt;b&gt;GameId reference&lt;/b&gt;&#xa;(Conformist)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#7d4e00;strokeWidth=2;fontColor=#7d4e00;fontSize=11;endArrow=open;startArrow=none;" edge="1" source="bc_catalog_container" target="bc_promo_container" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- User Management → Game Catalog (JWT Auth: Admin role gates writes) -->
