        </mxCell>

        <!-- Endpoints in Library -->
        <mxCell id="ep_library" value="Endpoints (User):&#xa;GET  /api/library&#xa;POST /api/library/{gameId}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#6d1313;fontSize=11;align=left;" vertex="1" parent="bc_library_container">
          <mxGeometry x="110" y="260" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
