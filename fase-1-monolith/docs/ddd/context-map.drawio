        <!-- User Management → Library (User provides identity to Library) -->
        <mxCell id="rel_user_library" value="&lt;b&gt;UserId reference&lt;/b&gt;&#xa;(Customer/Supplier)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#003399;strokeWidth=2;fontColor=#003399;fontSize=11;endArrow=open;startArrow=none;" edge="1" source="bc_user_container" target="bc_library_container" parent="1">
